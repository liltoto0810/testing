{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "config": {
    "background": "transparent",
    "font": "Inter, Arial, sans-serif",
    "axis": {
      "labelColor": "#3f4a4f",
      "titleColor": "#253136",
      "gridColor": "#e8ecef",
      "domainColor": "#ccd3d7",
      "tickColor": "#ccd3d7",
      "labelFontSize": 11,
      "titleFontSize": 12
    },
    "legend": {
      "labelColor": "#3f4a4f",
      "titleColor": "#253136",
      "labelFontSize": 11,
      "titleFontSize": 12,
      "orient": "bottom"
    },
    "title": {
      "fontSize": 16,
      "fontWeight": 700,
      "anchor": "start",
      "color": "#102026",
      "subtitleColor": "#526166",
      "subtitleFontSize": 12
    },
    "view": {
      "stroke": null
    },
    "range": {
      "category": [
        "#264653",
        "#2a9d8f",
        "#e9c46a",
        "#f4a261",
        "#e76f51",
        "#6a4c93",
        "#277da1",
        "#43aa8b"
      ]
    }
  },
  "width": "container",
  "height": 320,
  "title": {
    "text": "2024 to 2025 movement among top markets",
    "subtitle": "Slope idiom highlights momentum without hiding absolute market scale."
  },
  "data": {
    "url": "data/cleaned_arrivals.csv"
  },
  "transform": [
    {
      "filter": "datum.Rank_2025 <= 10"
    },
    {
      "fold": [
        "Arrivals_2024",
        "Arrivals_2025"
      ],
      "as": [
        "Year_Field",
        "Arrivals"
      ]
    },
    {
      "calculate": "datum.Year_Field == \"Arrivals_2024\" ? \"2024\" : \"2025\"",
      "as": "Year"
    }
  ],
  "mark": {
    "type": "line",
    "point": {
      "filled": true,
      "size": 70
    },
    "strokeWidth": 2
  },
  "encoding": {
    "x": {
      "field": "Year",
      "type": "ordinal",
      "title": null
    },
    "y": {
      "field": "Arrivals",
      "type": "quantitative",
      "axis": {
        "format": "~s"
      },
      "title": "Arrivals"
    },
    "color": {
      "field": "Country_Title",
      "type": "nominal",
      "legend": null
    },
    "detail": {
      "field": "Country_Title"
    },
    "tooltip": [
      {
        "field": "Country_Title",
        "title": "Market"
      },
      {
        "field": "Year"
      },
      {
        "field": "Arrivals",
        "format": ","
      }
    ]
  }
}