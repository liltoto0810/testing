{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "config": {
    "background": "transparent",
    "font": "Inter, Arial, sans-serif",
    "axis": {
      "labelColor": "#3f4a4f",
      "titleColor": "#253136",
      "gridColor": "#e8ecef",
      "domainColor": "#ccd3d7",
      "tickColor": "#ccd3d7",
      "labelFontSize": 11,
      "titleFontSize": 12
    },
    "legend": {
      "labelColor": "#3f4a4f",
      "titleColor": "#253136",
      "labelFontSize": 11,
      "titleFontSize": 12,
      "orient": "bottom"
    },
    "title": {
      "fontSize": 16,
      "fontWeight": 700,
      "anchor": "start",
      "color": "#102026",
      "subtitleColor": "#526166",
      "subtitleFontSize": 12
    },
    "view": {
      "stroke": null
    },
    "range": {
      "category": [
        "#264653",
        "#2a9d8f",
        "#e9c46a",
        "#f4a261",
        "#e76f51",
        "#6a4c93",
        "#277da1",
        "#43aa8b"
      ]
    }
  },
  "width": "container",
  "height": 360,
  "title": {
    "text": "State demand pressure ranking",
    "subtitle": "Guests per room is paired with AOR to identify places where demand may stress capacity."
  },
  "data": {
    "url": "data/state_tourism_2025.csv"
  },
  "transform": [
    {
      "window": [
        {
          "op": "rank",
          "as": "Pressure_Rank"
        }
      ],
      "sort": [
        {
          "field": "Guests_per_Room",
          "order": "descending"
        }
      ]
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 5
      },
      "encoding": {
        "y": {
          "field": "State",
          "type": "nominal",
          "sort": "-x",
          "title": null
        },
        "x": {
          "field": "Guests_per_Room",
          "type": "quantitative",
          "title": "Guests per room"
        },
        "color": {
          "field": "AOR_Q4",
          "type": "quantitative",
          "title": "Q4 AOR %",
          "scale": {
            "scheme": "viridis"
          }
        },
        "tooltip": [
          {
            "field": "State"
          },
          {
            "field": "Guests_per_Room",
            "format": ".0f"
          },
          {
            "field": "AOR_Q4",
            "format": ".1f"
          },
          {
            "field": "Foreign_Share",
            "format": ".1f"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 5,
        "fontSize": 10,
        "color": "#253136"
      },
      "encoding": {
        "y": {
          "field": "State",
          "type": "nominal",
          "sort": "-x"
        },
        "x": {
          "field": "Guests_per_Room",
          "type": "quantitative"
        },
        "text": {
          "field": "AOR_Q4",
          "format": ".1f"
        }
      }
    }
  ]
}