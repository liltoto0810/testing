{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "config": {
    "background": "transparent",
    "font": "Inter, Arial, sans-serif",
    "axis": {
      "labelColor": "#3f4a4f",
      "titleColor": "#253136",
      "gridColor": "#e8ecef",
      "domainColor": "#ccd3d7",
      "tickColor": "#ccd3d7",
      "labelFontSize": 11,
      "titleFontSize": 12
    },
    "legend": {
      "labelColor": "#3f4a4f",
      "titleColor": "#253136",
      "labelFontSize": 11,
      "titleFontSize": 12,
      "orient": "bottom"
    },
    "title": {
      "fontSize": 16,
      "fontWeight": 700,
      "anchor": "start",
      "color": "#102026",
      "subtitleColor": "#526166",
      "subtitleFontSize": 12
    },
    "view": {
      "stroke": null
    },
    "range": {
      "category": [
        "#264653",
        "#2a9d8f",
        "#e9c46a",
        "#f4a261",
        "#e76f51",
        "#6a4c93",
        "#277da1",
        "#43aa8b"
      ]
    }
  },
  "width": "container",
  "height": 360,
  "title": {
    "text": "Q4 occupancy spread by state",
    "subtitle": "Range-and-point idiom shows volatility while retaining the Q4 average."
  },
  "data": {
    "url": "data/state_tourism_2025.csv"
  },
  "transform": [
    {
      "calculate": "min(datum.Oct, min(datum.Nov, datum.Dec))",
      "as": "AOR_Min"
    },
    {
      "calculate": "max(datum.Oct, max(datum.Nov, datum.Dec))",
      "as": "AOR_Max"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "rule",
        "strokeWidth": 4,
        "strokeCap": "round",
        "color": "#ccd6da"
      },
      "encoding": {
        "y": {
          "field": "State",
          "type": "nominal",
          "sort": {
            "field": "AOR_Q4",
            "order": "descending"
          },
          "title": null
        },
        "x": {
          "field": "AOR_Min",
          "type": "quantitative",
          "title": "AOR (%)"
        },
        "x2": {
          "field": "AOR_Max"
        }
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 80,
        "color": "#264653"
      },
      "encoding": {
        "y": {
          "field": "State",
          "type": "nominal",
          "sort": {
            "field": "AOR_Q4",
            "order": "descending"
          }
        },
        "x": {
          "field": "AOR_Q4",
          "type": "quantitative"
        },
        "tooltip": [
          {
            "field": "State"
          },
          {
            "field": "AOR_Q4",
            "format": ".1f",
            "title": "Q4 AOR"
          },
          {
            "field": "AOR_Range",
            "format": ".1f",
            "title": "Oct-Dec range"
          }
        ]
      }
    }
  ]
}