{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "config": {
    "background": "transparent",
    "font": "Inter, Arial, sans-serif",
    "axis": {
      "labelColor": "#3f4a4f",
      "titleColor": "#253136",
      "gridColor": "#e8ecef",
      "domainColor": "#ccd3d7",
      "tickColor": "#ccd3d7",
      "labelFontSize": 11,
      "titleFontSize": 12
    },
    "legend": {
      "labelColor": "#3f4a4f",
      "titleColor": "#253136",
      "labelFontSize": 11,
      "titleFontSize": 12,
      "orient": "bottom"
    },
    "title": {
      "fontSize": 16,
      "fontWeight": 700,
      "anchor": "start",
      "color": "#102026",
      "subtitleColor": "#526166",
      "subtitleFontSize": 12
    },
    "view": {
      "stroke": null
    },
    "range": {
      "category": [
        "#264653",
        "#2a9d8f",
        "#e9c46a",
        "#f4a261",
        "#e76f51",
        "#6a4c93",
        "#277da1",
        "#43aa8b"
      ]
    }
  },
  "width": "container",
  "height": 450,
  "title": {
    "text": "Demand pressure: hotel guests per room",
    "subtitle": "A performance map normalises demand by supply, so smaller-capacity states are not hidden."
  },
  "projection": {
    "type": "mercator"
  },
  "layer": [
    {
      "data": {
        "url": "data/malaysia-states.topojson",
        "format": {
          "type": "topojson",
          "feature": "states"
        }
      },
      "transform": [
        {
          "lookup": "properties.Name",
          "from": {
            "data": {
              "url": "data/state_tourism_2025.csv"
            },
            "key": "Topo_State",
            "fields": [
              "State",
              "Guests_per_Room",
              "Total_2025",
              "Rooms",
              "Foreign_Share"
            ]
          }
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "white",
        "strokeWidth": 1.2
      },
      "encoding": {
        "color": {
          "field": "Guests_per_Room",
          "type": "quantitative",
          "title": "Guests per room",
          "scale": {
            "scheme": "orangered"
          }
        },
        "tooltip": [
          {
            "field": "State"
          },
          {
            "field": "Guests_per_Room",
            "format": ".0f"
          },
          {
            "field": "Total_2025",
            "format": ","
          },
          {
            "field": "Rooms",
            "format": ","
          },
          {
            "field": "Foreign_Share",
            "format": ".1f"
          }
        ]
      }
    }
  ]
}