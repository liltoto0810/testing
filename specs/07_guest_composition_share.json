{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "config": {
    "background": "transparent",
    "font": "Inter, Arial, sans-serif",
    "axis": {
      "labelColor": "#3f4a4f",
      "titleColor": "#253136",
      "gridColor": "#e8ecef",
      "domainColor": "#ccd3d7",
      "tickColor": "#ccd3d7",
      "labelFontSize": 11,
      "titleFontSize": 12
    },
    "legend": {
      "labelColor": "#3f4a4f",
      "titleColor": "#253136",
      "labelFontSize": 11,
      "titleFontSize": 12,
      "orient": "bottom"
    },
    "title": {
      "fontSize": 16,
      "fontWeight": 700,
      "anchor": "start",
      "color": "#102026",
      "subtitleColor": "#526166",
      "subtitleFontSize": 12
    },
    "view": {
      "stroke": null
    },
    "range": {
      "category": [
        "#264653",
        "#2a9d8f",
        "#e9c46a",
        "#f4a261",
        "#e76f51",
        "#6a4c93",
        "#277da1",
        "#43aa8b"
      ]
    }
  },
  "width": "container",
  "height": 360,
  "title": {
    "text": "Domestic versus foreign guest composition",
    "subtitle": "A normalised stacked bar shows whether state demand is local-led or international-facing."
  },
  "data": {
    "url": "data/state_tourism_2025.csv"
  },
  "transform": [
    {
      "fold": [
        "Domestic_2025",
        "Foreign_2025"
      ],
      "as": [
        "Guest_Type",
        "Guests"
      ]
    },
    {
      "calculate": "datum.Guest_Type == 'Domestic_2025' ? 'Domestic guests' : 'Foreign guests'",
      "as": "Type_Label"
    }
  ],
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 3
  },
  "encoding": {
    "y": {
      "field": "State",
      "type": "nominal",
      "sort": "-x",
      "title": null
    },
    "x": {
      "field": "Guests",
      "type": "quantitative",
      "stack": "normalize",
      "axis": {
        "format": "%"
      },
      "title": "Share of hotel guests"
    },
    "color": {
      "field": "Type_Label",
      "type": "nominal",
      "title": null,
      "scale": {
        "range": [
          "#2a9d8f",
          "#e76f51"
        ]
      }
    },
    "tooltip": [
      {
        "field": "State"
      },
      {
        "field": "Type_Label",
        "title": "Type"
      },
      {
        "field": "Guests",
        "format": ","
      },
      {
        "field": "Foreign_Share",
        "format": ".1f",
        "title": "Foreign share %"
      }
    ]
  }
}